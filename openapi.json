            "description": "Список популярных ОКВЭД"
          }
        }
      }
    },

    "/files/upload": {
      "post": {
        "tags": ["Files"],
        "summary": "Загрузить файл",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Загруженный файл",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Attachment" }
              }
            }
          }
        }
      }
    },
    "/files/business/{businessId}": {
      "get": {
        "tags": ["Files"],
        "summary": "Получить файлы бизнес-проекта",
        "parameters": [
          {
            "name": "businessId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Список файлов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Attachment" }
                }
              }
            }
          }
        }
      }
    },
    "/files/{id}": {
      "delete": {
        "tags": ["Files"],
        "summary": "Удалить файл",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Файл удален" }
        }
      }
    },

    "/ai/models": {
      "get": {
        "tags": ["AI"],
        "summary": "Список доступных ИИ-моделей с информацией о подписке",
        "responses": {
          "200": {
            "description": "Доступные модели и лимиты",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "default": { "type": "string" },
                    "subscription": {
                      "type": "object",
                      "properties": {
                        "plan": { "type": "string" },
                        "until": { "type": "string", "format": "date-time" },
                        "isActive": { "type": "boolean" },
                        "limit": { "type": "integer" },
                        "windowHours": { "type": "integer" }
                      }
                    },
                    "tiers": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AIModelTier" }
                    },
                    "planLimits": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/ai/usage": {
      "get": {
        "tags": ["AI"],
        "summary": "Текущее использование квоты сообщений",
        "responses": {
          "200": {
            "description": "Использование квоты",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "used": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "remaining": { "type": "integer" },
                    "windowHours": { "type": "integer" },
                    "resetsAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/admin/stats": {
      "get": {
        "tags": ["Admin"],
        "summary": "Статистика системы (только для ADMIN)",
        "responses": {
          "200": {
            "description": "Статистика"
          }
        }
      }
    },
    "/admin/plans": {
      "get": {
        "tags": ["Admin"],
        "summary": "Список конфигураций планов",
        "responses": {
          "200": {
            "description": "Конфигурации планов",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/PlanConfig" }
                }
              }
            }
          }
        }
      }
    },
    "/admin/plans/{plan}": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Обновить конфигурацию плана",
        "parameters": [
          {
            "name": "plan",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "enum": ["FREE", "PLUS", "PREMIUM"] }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "messagesPerWindow": { "type": "integer", "minimum": 1, "maximum": 100000 },
                  "windowHours": { "type": "integer", "minimum": 1, "maximum": 168 },
                  "label": { "type": "string", "minLength": 1, "maxLength": 40 },
                  "description": { "type": "string", "maxLength": 500, "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновленная конфигурация",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PlanConfig" }
              }
            }
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "Список пользователей с фильтрацией и пагинацией",
        "parameters": [
          {
            "name": "search",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Поиск по email, имени"
          },
          {
            "name": "plan",
            "in": "query",
            "schema": { "type": "string", "enum": ["FREE", "PLUS", "PREMIUM"] }
          },
          {
            "name": "role",
            "in": "query",
            "schema": { "type": "string", "enum": ["USER", "ADMIN"] }
          },
          {
            "name": "blocked",
            "in": "query",
            "schema": { "type": "string", "enum": ["true", "false"] }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "default": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Список пользователей с пагинацией"
          }
        }
      }
    },
    "/admin/users/{id}": {
      "get": {
        "tags": ["Admin"],
        "summary": "Детали пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Данные пользователя"
          }
        }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Удалить пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Пользователь удален" }
        }
      }
    },
    "/admin/users/{id}/subscription": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Обновить подписку пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["plan"],
                "properties": {
                  "plan": { "type": "string", "enum": ["FREE", "PLUS", "PREMIUM"] },
                  "until": { "type": "string", "format": "date-time", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновленный пользователь"
          }
        }
      }
    },
    "/admin/users/{id}/role": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Изменить роль пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["role"],
                "properties": {
                  "role": { "type": "string", "enum": ["USER", "ADMIN"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Роль обновлена"
          }
        }
      }
    },
    "/admin/users/{id}/blocked": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Заблокировать/разблокировать пользователя",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["blocked"],
                "properties": {
                  "blocked": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Статус блокировки обновлен"
          }
        }
      }
    }
  }
}
