            "in": "path",
            "required": true,
            "schema": { "type": "string", "pattern": "^[0-9]{13}$" }
          }
        ],
        "responses": {
          "200": {
            "description": "Данные компании",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FnsCompany" }
              }
            }
          }
        }
