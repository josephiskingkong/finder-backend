generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== ПОЛЬЗОВАТЕЛИ ====================

/// План подписки пользователя.
/// FREE    — бесплатный (только бесплатные модели, которые будут добавлены позже).
/// PLUS    — доступ к модели Сбер GigaChat (наш tier PLUS).
/// PREMIUM — все модели (PLUS + PREMIUM=OpenAI).
enum SubscriptionPlan {
  FREE
  PLUS
  PREMIUM
}

/// Роль пользователя в системе. ADMIN получает доступ к админ-API.
enum UserRole {
  USER
  ADMIN
}

/// Конфигурация лимитов на план подписки. Хранится в БД, чтобы админ мог менять
/// без передеплоя. Одна строка на каждый SubscriptionPlan.
/// Читается в subscription.service с in-memory кэшем (TTL 60 сек).
model PlanConfig {
  plan              SubscriptionPlan @id
  /// Сколько USER-сообщений можно отправить в чат за rolling-window.
  messagesPerWindow Int              @map("messages_per_window")
  /// Длина окна в часах (например, 6).
  windowHours       Int              @map("window_hours")
  /// Человеко-читаемый ярлык для админки и страницы тарифов.
  label             String
  /// Опциональная описание плана для админки.
  description       String?
  updatedAt         DateTime         @updatedAt @map("updated_at")

  @@map("plan_configs")
}

model User {
  id                String           @id @default(uuid())
  email             String           @unique
  passwordHash      String           @map("password_hash")
  firstName         String?          @map("first_name")
  lastName          String?          @map("last_name")
  role              UserRole         @default(USER)
  subscription      SubscriptionPlan @default(FREE)
  /// Дата окончания платной подписки. null = бессрочно (например, для бесплатного плана).
  subscriptionUntil DateTime?        @map("subscription_until")
  isBlocked         Boolean          @default(false) @map("is_blocked")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  entrepreneurProfile EntrepreneurProfile?
  businesses          Business[]
  refreshTokens       RefreshToken[]

  @@index([role])
  @@index([subscription])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==================== ПРОФИЛЬ ПРЕДПРИНИМАТЕЛЯ ====================

enum EntrepreneurType {
  DOMAIN_EXPERT      // Разбирается в предметной области, но не в бизнесе
  COMPLETE_BEGINNER   // Не разбирается ни в бизнесе, ни в предметной области
  UNKNOWN            // Ещё не определён
}

model EntrepreneurProfile {
  id                  String           @id @default(uuid())
  userId              String           @unique @map("user_id")
  type                EntrepreneurType @default(UNKNOWN)
  experienceYears     Int?             @map("experience_years")
  industryKnowledge   String?          @map("industry_knowledge")
  hasExistingBusiness Boolean          @default(false) @map("has_existing_business")
  motivationNotes     String?          @map("motivation_notes")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("entrepreneur_profiles")
}

// ==================== БИЗНЕС-ПРОЕКТ ====================

enum BusinessStatus {
  IDEA_GENERATION
  IDEA_DEFINED
  ANALYSIS
  VALIDATION
  MVP
  ITERATION
  LAUNCHED
}

model Business {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  title       String
  description String?
  industry    String?
  status      BusinessStatus @default(IDEA_GENERATION)

  problemStatement  String?  @map("problem_statement")
  targetAudience    String?  @map("target_audience")
  uniqueValue       String?  @map("unique_value")
  competitors       String?
  monetizationModel String?  @map("monetization_model")
  marketSize        String?  @map("market_size")
  hypotheses        String?
  interviewResults  String?  @map("interview_results")
  // Interview hypotheses (replacing mvpDescription)

  inn        String?
  ogrn       String?
  legalForm  String?  @map("legal_form")
  taxSystem  String?  @map("tax_system")
  okvedCodes String?  @map("okved_codes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap  Roadmap?
  chats    Conversation[]
  files    Attachment[]
  interviewHypotheses Hypothesis[] // Гипотезы для проверки на интервью

  @@map("businesses")
}

// ==================== РОАДМАП ====================

enum RoadmapPhase {
  PROBLEMATIZATION
  PRODUCT_STUDY
  MARKET_ANALYSIS
  MONETIZATION
  USER_INTERVIEWS
  MVP_CREATION       // DEPRECATED: оставлен для совместимости с существующими данными
  REPEAT_CUSTDEV
  REGISTRATION
  ACCOUNTING
}

model Roadmap {
  id         String   @id @default(uuid())
  businessId String   @unique @map("business_id")
  version    Int      @default(1)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  steps    RoadmapStep[]

  @@map("roadmaps")
}

enum StepStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  SKIPPED
  FAILED
}

model RoadmapStep {
  id          String       @id @default(uuid())
  roadmapId   String       @map("roadmap_id")
  phase       RoadmapPhase
  order       Int
  title       String
  description String
  tips        String?
  status      StepStatus   @default(LOCKED)

  userReport   String?   @map("user_report")
  userFeedback String?   @map("user_feedback")
  aiAnalysis   String?   @map("ai_analysis")
  completedAt  DateTime? @map("completed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roadmap     Roadmap          @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  attachments StepAttachment[]

  @@map("roadmap_steps")
}

// ==================== ЧАТ ====================

/// Уровень/провайдер ИИ-модели, выбираемый пользователем во фронте.
/// PREMIUM = OpenAI GPT, PLUS = Сбер GigaChat.
enum AiTier {
  PREMIUM
  PLUS
}

model Conversation {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  title      String?
  aiTier     AiTier   @default(PREMIUM) @map("ai_tier")
  /// Сжатая выжимка прошлых сообщений (rolling summary). null = ещё не было сжатия,
  /// беседа короткая и идёт в LLM целиком.
  summary    String?
  /// Отсечка: все сообщения с createdAt <= этого момента считаются ужатыми в `summary`.
  /// Recent buffer берётся как сообщения с createdAt > summaryUpTo.
  summaryUpTo         DateTime? @map("summary_up_to")
  /// Сколько сообщений уже учтено в summary — нужно чтобы дёшево решить,
  /// пора ли перестраивать выжимку, без COUNT(*) на каждом запросе.
  summarizedCount     Int       @default(0) @map("summarized_count")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  business Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages Message[]

  @@map("conversations")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Message {
  id             String      @id @default(uuid())
  conversationId String      @map("conversation_id")
  role           MessageRole
  content        String
  metadata       String?
  createdAt      DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ==================== ФАЙЛЫ ====================

model Attachment {
  id         String   @id @default(uuid())
  businessId String   @map("business_id")
  filename   String
  mimetype   String
  size       Int
  path       String
  createdAt  DateTime @default(now()) @map("created_at")

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stepAttachments StepAttachment[]

  @@map("attachments")
}

model StepAttachment {
  id           String @id @default(uuid())
  stepId       String @map("step_id")
  attachmentId String @map("attachment_id")

  step       RoadmapStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  attachment Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([stepId, attachmentId])
  @@map("step_attachments")
}

// ==================== ИНТЕРВЬЮ / ГИПОТЕЗЫ ====================

enum HypothesisStatus {
  PENDING      // Ожидает проверки
  CONFIRMED    // Подтверждена интервью
  REJECTED     // Опровергнута
  PARTIALLY    // Частично подтверждена
}

/// Гипотеза бизнес-проекта для проверки через интервью
model Hypothesis {
  id          String           @id @default(uuid())
  businessId  String           @map("business_id")
  statement   String           // Текст гипотезы (например: "Пользователи готовы платить 500р за доставку за 1 час")
  category    String           // Категория: проблема, решение, цена, канал и т.д.
  status      HypothesisStatus @default(PENDING)
  isAiGenerated Boolean        @default(false) @map("is_ai_generated")
  priority    Int              @default(1)      // Приоритет проверки (1-5)
  
  // Результаты проверки
  evidenceSummary String?      @map("evidence_summary") // Сводка доказательств из интервью
  confirmedCount  Int          @default(0) @map("confirmed_count")   // Сколько раз подтверждена
  rejectedCount   Int          @default(0) @map("rejected_count")    // Сколько раз отвергнута
  
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  business  Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  questions InterviewQuestion[]
  findings  InterviewFinding[]

  @@index([businessId])
  @@index([status])
  @@map("hypotheses")
}

/// Вопрос для проверки гипотезы на интервью
model InterviewQuestion {
  id            String   @id @default(uuid())
  hypothesisId  String   @map("hypothesis_id")
  question      String   // Текст вопроса
  questionType  String   @default("open") @map("question_type") // open, yes_no, scale
  isAiGenerated Boolean  @default(false) @map("is_ai_generated")
  order         Int      @default(0)
  
  createdAt     DateTime @default(now()) @map("created_at")

  hypothesis Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  @@index([hypothesisId])
  @@map("interview_questions")
}

/// Результат проверки гипотезы в конкретном интервью
model InterviewFinding {
  id           String   @id @default(uuid())
  hypothesisId String   @map("hypothesis_id")
  interviewee  String   // Имя/идентификатор респондента
  notes        String?  // Заметки из интервью
  verdict      String   // confirmed, rejected, unclear
  
  createdAt    DateTime @default(now()) @map("created_at")

  hypothesis Hypothesis @relation(fields: [hypothesisId], references: [id], onDelete: Cascade)

  @@index([hypothesisId])
  @@map("interview_findings")
}

// ==================== КЭШ ДАННЫХ ФНС / КОНКУРЕНТОВ ====================

/// Кэш карточек компаний, полученных из API ФНС (api-fns.ru) по ИНН.
/// Используется для повторного использования между пользователями (TTL ~ 7 дней).
model FnsCompanyCache {
  id          String   @id @default(uuid())
  inn         String   @unique
  ogrn        String?
  name        String
  /// Сырая структурированная карточка (JSON-строка) — то, что мы отдаём наружу.
  payload     String
  /// Когда запись истекает и должна быть перезапрошена.
  expiresAt   DateTime @map("expires_at")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("fns_company_cache")
}

/// Кэш результатов поиска по строковому запросу (название/отрасль/город).
/// Хранит топ-N найденных ИНН — детали лежат в FnsCompanyCache.
model FnsSearchCache {
  id        String   @id @default(uuid())
  /// Нормализованный поисковый ключ (lowercase, обрезанные пробелы).
  query     String   @unique
  /// JSON-массив строк ИНН в порядке релевантности.
  innList   String   @map("inn_list")
  expiresAt DateTime @map("expires_at")
  fetchedAt DateTime @default(now()) @map("fetched_at")

  @@index([expiresAt])
  @@map("fns_search_cache")
}
